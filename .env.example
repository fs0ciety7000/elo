# ============================================================
# Antigravity Medical SaaS — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement
# ============================================================

# URL de base de l'application
AUTH_URL=https://elodie.fs0ciety.org

# Clé secrète pour la signature des tokens JWT (32 chars minimum)
AUTH_SECRET=

# ── Google Cloud Vision (OCR) ──────────────────────────────
GOOGLE_VISION_API_KEY=

# ── Base de données PostgreSQL ─────────────────────────────
POSTGRES_USER=medical
POSTGRES_PASSWORD=
POSTGRES_DB=medical_db

# URL de connexion Prisma (le @ doit être encodé en %40 dans l'URL)
DATABASE_URL=

# ── Resend (mailing) ───────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@elodie.fs0ciety.org

# ── Coolify / Traefik ──────────────────────────────────────
SERVICE_URL_MEDICAL_APP=https://elodie.fs0ciety.org
SERVICE_FQDN_MEDICAL_APP=elodie.fs0ciety.org
